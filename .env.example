# Telegram: create a bot via @BotFather
TELEGRAM_BOT_TOKEN=

# Local SQLite (default): sqlite+aiosqlite:///./data/app.db
# Free Postgres (Neon, Supabase, etc.):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/postgres

DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Optional: API base URL if the bot should call the HTTP API (same machine example)
# API_BASE_URL=http://127.0.0.1:8000

# متن دکمه‌ها و پاسخ بعد از کلیک (پیش‌فرض در کد فارسی است)
# START_BUTTON_1_TEXT=قصد فروش ارز و دریافت ریال دارم
# START_BUTTON_2_TEXT=قصد خرید ارز و پرداخت ریال دارم
# START_BUTTON_1_REPLY=...
# START_BUTTON_2_REPLY=...  # unused: خرید از فهرست آگهی‌ها در ربات است
# تعداد آگهی در هر صفحهٔ فهرست خرید (۱ تا ۳۰؛ پیش‌فرض ۲۰)
# BUYER_CATALOG_PAGE_SIZE=20
