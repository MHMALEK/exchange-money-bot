# Telegram: create a bot via @BotFather
TELEGRAM_BOT_TOKEN=

# Local SQLite (default): sqlite+aiosqlite:///./data/app.db
# Free Postgres (Neon, Supabase, etc.):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/postgres

DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Optional: API base URL if the bot should call the HTTP API (same machine example)
# API_BASE_URL=http://127.0.0.1:8000

# User-visible copy: exchange_money_bot/locales/fa.py (add locales/en.py later).
# Default language: DEFAULT_LOCALE in exchange_money_bot/constants.py.

# Required: listings channel (@username or -100…). Bot must be admin. Offers are posted here only.
TELEGRAM_LISTINGS_CHANNEL_ID=-100xxxxxxxxxx

# Optional auth — only if you want to restrict the bot:
# TELEGRAM_MEMBERSHIP_CHANNEL_ID=-100xxxxxxxxxx
#   If set: user must be a member of this channel when auth is enforced.
# TELEGRAM_MEMBERSHIP_GROUP_ID=-100xxxxxxxxxx
#   If set: user must be a member of this group when auth is enforced.
# If BOTH are set: user must be in the channel AND the group.
# If NEITHER is set: no membership gate (unless you use TELEGRAM_DISABLE_MEMBERSHIP_GATE below).
# TELEGRAM_MEMBERSHIP_GROUP_INVITE_URL=https://t.me/+invite   # optional join link for the group button

# Local/dev: skip all auth checks (do not use in production).
# TELEGRAM_DISABLE_MEMBERSHIP_GATE=false

# Optional: public join/open URL for the listings channel (private channels often need this).
# TELEGRAM_CHANNEL_INVITE_URL=https://t.me/+invite

# USD/EUR → rial snapshot for the «نرخ زنده و معادل ریالی» menu (margani/pricedb TGJU JSON by default).
# IRR_RATES_TTL_SECONDS=300
# IRR_USD_JSON_URL=
# IRR_EUR_JSON_URL=
